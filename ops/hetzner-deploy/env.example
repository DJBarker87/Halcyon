# Hetzner Halcyon keeper env file.
# Copy to /etc/halcyon/env on the server, then edit in place.

# Git / checkout
HALCYON_REPO_URL=git@github.com:DJBarker87/Halcyon.git
HALCYON_BRANCH=main
HALCYON_REF=

# Toolchain pins
# This repo currently has no rust-toolchain.toml, so deploy.sh falls back to
# this explicit Rust toolchain version.
RUST_TOOLCHAIN_VERSION=1.93.0
SOLANA_INSTALL_VERSION=2.3.0
NODE_MAJOR=20
CARGO_BUILD_JOBS=1

# Shared RPC / logging
HELIUS_DEVNET_RPC=https://devnet.helius-rpc.com/?api-key=REPLACE_ME
HERMES_ENDPOINT=https://hermes.pyth.network
RUST_LOG=info
RUST_BACKTRACE=1

# Enable flags. The defaults below are the current devnet demo path.
ENABLE_PRICE_RELAY=1
ENABLE_OBSERVATION_KEEPER=1
ENABLE_REGIME_KEEPER=1
ENABLE_IL_EWMA_TIMER=1
ENABLE_SOL_EWMA_TIMER=1
ENABLE_FLAGSHIP_EWMA_TIMER=0
ENABLE_FLAGSHIP_SIGMA_TIMER=1
ENABLE_REDUCED_OPS_TIMER=1
ENABLE_AUTOCALL_SCHEDULE_TIMER=1
ENABLE_MOCK_USDC_FAUCET=1

# Optional / heavier / incomplete keepers. Leave off unless you need them.
ENABLE_WRITE_REGRESSION_TIMER=0
ENABLE_DELTA_KEEPER=0
ENABLE_HEDGE_KEEPER=0
ENABLE_FLAGSHIP_HEDGE_KEEPER=0
ENABLE_LEGACY_REGRESSION_KEEPER=0

# Program IDs from Anchor.toml [programs.devnet]
KERNEL_PROGRAM_ID=H71FxCTuVGL13PkzXeVxeTn89xZreFm4AwLu3iZeVtdF
LENDING_CONSUMER_PROGRAM_ID=BSZABrfDG1vN3q7sejfebPFbqfqwVRu8gcjSukWEiXqF
IL_PROGRAM_ID=HuUQUngf79HgTWdggxAsE135qFeHfYV9Mj9xsCcwqz5g
SOL_PROGRAM_ID=6DfpE7MEx1K1CeiQuw8Q61Empamcuknv9Tc79xtJKae8
FLAGSHIP_PROGRAM_ID=E4Atu2kHkzJ1NMATBvoMcy3BDKfsyz418DHCoqQHc3Mc

# Devnet assets / relay shard.
# Use Halcyon's mock-USDC mint, not Circle devnet USDC, so judges can use
# the app faucet.
USDC_MINT=REPLACE_DEVNET_MOCK_USDC_MINT
PRICE_RELAY_SHARD_ID=7

# Devnet deterministic Pyth PriceUpdateV2 accounts currently used by Halcyon.
PYTH_SOL_ACCOUNT=ES2Q48KYND5GKYynzJT8RUm3kzwru1stmHnPNyrdhASn
PYTH_USDC_ACCOUNT=E3Yadhsse8urMFZ2ERZgLZzcgm5DNZpTiHHeoT9yFfTH
PYTH_SPY_ACCOUNT=Dix5qyQ52TtpErut1z6DUqmzVbqNfyCcjf1XvArJnwwY
PYTH_QQQ_ACCOUNT=4Np4uL4vYhumfDAZeootLniVqrGhaK83Vh9WcQJwANmG
PYTH_IWM_ACCOUNT=GoUfqZ5jdJEi4gnLUoajt5PLqHyVzbUAi8KRGaBczYsZ

# Keypairs. KeeperRegistry-bound roles must match the registered authorities.
PRICE_RELAY_KEYPAIR=/root/halcyon-keys/price-relay.json
OBSERVATION_KEYPAIR=/root/halcyon-keys/observation.json
REGRESSION_KEYPAIR=/root/halcyon-keys/regression.json
DELTA_KEYPAIR=/root/halcyon-keys/delta.json
HEDGE_KEYPAIR=/root/halcyon-keys/hedge.json
REGIME_KEYPAIR=/root/halcyon-keys/regime.json
FLAGSHIP_HEDGE_KEYPAIR=/root/halcyon-keys/flagship-hedge.json
IL_EWMA_KEYPAIR=/root/halcyon-keys/il-ewma.json
SOL_EWMA_KEYPAIR=/root/halcyon-keys/sol-ewma.json
FLAGSHIP_EWMA_KEYPAIR=/root/halcyon-keys/flagship-ewma.json
FLAGSHIP_SIGMA_KEYPAIR=/root/halcyon-keys/flagship-sigma.json

# Native keeper config defaults
PRICE_RELAY_SCAN_INTERVAL_SECS=10
PRICE_RELAY_STALENESS_CAP_SECS=30
PRICE_RELAY_CACHE_DIR=/var/lib/halcyon/relay-cache
PRICE_RELAY_CACHE_RETENTION_DAYS=450
PRICE_RELAY_CACHE_FEEDS=SOL_USD,USDC_USD,SPY_USD,QQQ_USD,IWM_USD
PRICE_RELAY_FAILURE_BUDGET=5
PRICE_RELAY_BACKOFF_CAP_SECS=60
PRICE_RELAY_MIN_BALANCE_SOL=0.25

OBSERVATION_SCAN_INTERVAL_SECS=60
OBSERVATION_BACKOFF_CAP_SECS=60
OBSERVATION_FAILURE_BUDGET=5

REGIME_HISTORY_URL=https://api.coingecko.com/api/v3/coins/solana/market_chart?vs_currency=usd&days=120&interval=daily
REGIME_SCAN_INTERVAL_SECS=3600
REGIME_BACKOFF_CAP_SECS=300
REGIME_FAILURE_BUDGET=5

REGRESSION_SCAN_INTERVAL_SECS=86400
REGRESSION_BACKOFF_CAP_SECS=900
REGRESSION_FAILURE_BUDGET=5
REGRESSION_SPY_HISTORY_URL=https://stooq.com/q/d/l/?s=spy.us&i=d
REGRESSION_QQQ_HISTORY_URL=https://stooq.com/q/d/l/?s=qqq.us&i=d
REGRESSION_IWM_HISTORY_URL=https://stooq.com/q/d/l/?s=iwm.us&i=d

DELTA_SCAN_INTERVAL_SECS=30
DELTA_BACKOFF_CAP_SECS=60
DELTA_FAILURE_BUDGET=5
DELTA_MERKLE_OUTPUT_PATH=/var/lib/halcyon/flagship_delta.json
PINATA_BASE_URL=https://api.pinata.cloud
PINATA_RETRIES=3

HEDGE_SCAN_INTERVAL_SECS=60
HEDGE_BACKOFF_CAP_SECS=60
HEDGE_FAILURE_BUDGET=5
HEDGE_DRY_RUN=true

FLAGSHIP_HEDGE_SCAN_INTERVAL_SECS=300
FLAGSHIP_HEDGE_BACKOFF_CAP_SECS=60
FLAGSHIP_HEDGE_FAILURE_BUDGET=5
FLAGSHIP_HEDGE_AGGREGATE_DELTA_MAX_AGE_SECS=1800
FLAGSHIP_HEDGE_AGGREGATE_DELTA_MAX_SPOT_DRIFT_BPS=50
FLAGSHIP_HEDGE_REGRESSION_MAX_AGE_SECS=432000
FLAGSHIP_HEDGE_REBALANCE_COOLDOWN_SECS=432000
FLAGSHIP_HEDGE_REBALANCE_BREACH_MULTIPLE_BPS=15000
FLAGSHIP_HEDGE_LEG_BAND_WIDTH_BPS=1000
FLAGSHIP_HEDGE_LEG_MIN_TRADE_BPS=100

# Regression bootstrap CLI defaults. These files are not in this repo; upload
# them separately from ../Colosseum/halcyon-hedge-lab/data/cache/.
REGRESSION_SPY_HISTORY_SOURCE=/etc/halcyon/calibration/spy_1d.csv
REGRESSION_QQQ_HISTORY_SOURCE=/etc/halcyon/calibration/qqq_1d.csv
REGRESSION_IWM_HISTORY_SOURCE=/etc/halcyon/calibration/iwm_1d.csv

# Flagship sigma keeper defaults. The Pyth Benchmarks API currently needs no
# auth token. The keeper fetches daily bars in <=1-year chunks and will abort
# if the fixed-date sigma drift exceeds the 1% acceptance band.
FLAGSHIP_SIGMA_SPY_HISTORY_SOURCE=pyth:0x19e09bb805456ada3979a7d1cbb4b6d63babc3a0f8e8a9509f68afa5c4c11cd5
FLAGSHIP_SIGMA_CROSSCHECK_SOURCE=pyth:0x19e09bb805456ada3979a7d1cbb4b6d63babc3a0f8e8a9509f68afa5c4c11cd5
FLAGSHIP_SIGMA_PYTH_BENCHMARKS_BASE_URL=https://benchmarks.pyth.network
FLAGSHIP_SIGMA_CACHE_PATH=/var/lib/halcyon/spy_1d.csv

# Judge faucet. Create these with tools/mock_usdc_faucet/create-mint.mjs.
MOCK_USDC_MINT=${USDC_MINT}
MOCK_USDC_FAUCET_KEYPAIR_PATH=/root/halcyon-keys/mock-usdc-faucet.json
MOCK_USDC_FAUCET_AMOUNT=25000
MOCK_USDC_FAUCET_MAX_AMOUNT=25000
MOCK_USDC_FAUCET_COOLDOWN_MS=3600000
MOCK_USDC_FAUCET_ALLOWED_ORIGINS=https://halcyonprotocol.xyz,https://www.halcyonprotocol.xyz,http://localhost:3000,http://localhost:3001
PORT=8787

# Secrets for optional keepers
# `PINATA_JWT` is required when `ENABLE_DELTA_KEEPER=1`.
PINATA_JWT=
JUPITER_API_KEY=
