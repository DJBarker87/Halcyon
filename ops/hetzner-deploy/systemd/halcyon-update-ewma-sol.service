[Unit]
Description=Halcyon SOL EWMA updater
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/halcyon
EnvironmentFile=/etc/halcyon/env
ExecStart=/usr/bin/env bash -lc 'exec /opt/halcyon/bin/halcyon --rpc "$HELIUS_DEVNET_RPC" --keypair "$SOL_EWMA_KEYPAIR" update-ewma --product sol --oracle-price "$PYTH_SOL_ACCOUNT"'
StandardOutput=journal
StandardError=journal
SyslogIdentifier=halcyon-update-ewma-sol
