# Template environment file for every Halcyon keeper systemd service.
#
# Copy to /etc/halcyon/env/<keeper>.env on the host, fill in the blanks,
# and `chmod 600`. The matching .service unit reads the file via
# `EnvironmentFile=/etc/halcyon/env/<keeper>.env`.
#
# NEVER commit a populated copy. `.env.example` is safe to track; the
# real file lives only on the host.

# Delta keeper — requires Pinata JWT (audit F4a).
PINATA_JWT=

# Hedge keepers (SOL Autocall + flagship) — require Jupiter API key.
JUPITER_API_KEY=

# Shared: log filter. `info` is the launch default; `halcyon_kernel=debug`
# or `delta_keeper=trace` is useful during incidents.
RUST_LOG=info

# Shared: Rust panic behaviour. `full` emits a stack trace to journald
# for postmortem; otherwise panics are silent.
RUST_BACKTRACE=full
