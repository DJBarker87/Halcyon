[Unit]
Description=Halcyon SOL hedge keeper
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/halcyon
EnvironmentFile=/etc/halcyon/env
ExecStart=/opt/halcyon/bin/hedge_keeper --config /etc/halcyon/config/hedge_keeper.json
Restart=always
RestartSec=10s
StartLimitIntervalSec=300
StartLimitBurst=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=halcyon-hedge-keeper

[Install]
WantedBy=multi-user.target
