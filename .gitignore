# macOS
.DS_Store

# Rust build artifacts (root + any nested workspace/crate)
target/
/target
.anchor/
target/deploy/*-keypair.json
**/*keypair*.json
**/*.pem
**/*.key

# Node / JS
**/node_modules/
frontend/.next/
frontend/test-results/
frontend/playwright-report/
frontend/.turbo/
frontend/.vercel/

# Local tool state
.claude/*.lock

# Logs & scratch JSON at repo root
*.log
/*.json

# Marketing — large rendered artifacts (keep src, remotion config, package.json)
marketing-video/out/
*.mp4
*.mov
*.webm
.env
.env.*

# Price-relay local config — carries the Helius key + keypair path. The
# *.example.json siblings ARE tracked.
keepers/price_relay/config/*.json
!keepers/price_relay/config/*.example.json

# Locally-generated keeper keypairs for devnet. Live outside ~/.config
# so they sit next to the operator runbook but never land in git.
ops/devnet_keys/
ops/mainnet_keys/
